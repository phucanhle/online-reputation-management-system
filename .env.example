# Google Maps API Key for Cloud Run / Proxies
NEXT_PUBLIC_CLOUD_RUN_API_KEY="your_api_key_here"

# MongoDB Connection String
MONGODB_URI="mongodb+srv://..."

# Scraper Configuration
# Absolute URL of the FastAPI scraper backend (e.g., https://scraper-api.yourdomain.com)
API_SERVER_URL="http://localhost:8000"
# Absolute path to the scraper backend directory (local only)
SCRAPER_DIR="C:/path/to/google-reviews-scraper-pro-master"
# Command to run python (e.g., 'py', 'python', 'python3')
PYTHON_CMD="py"
# Config file name
SCRAPER_CONFIG="config.yaml"
